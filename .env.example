# Server
PORT=3005
NODE_ENV=development

# CORS — comma-separated list of allowed origins for cookie-credentialed requests
CORS_ORIGIN=http://localhost:5173

# Cookies
COOKIE_DOMAIN=localhost

# Database driver: `sqlite` (default, zero-config) or `postgres`.
DATABASE_CLIENT=sqlite

# SQLite — file path relative to backend/ (or absolute).
# Used only when DATABASE_CLIENT=sqlite. Run `npm run migrate` then
# `npm run seed` to initialise it.
DATABASE_PATH=db/vitalize.sqlite

# PostgreSQL — connection string.
# Required when DATABASE_CLIENT=postgres. Matches docker-compose.yml.
# Spin up local Postgres with: cd backend && docker compose up -d
DATABASE_URL=postgres://vitalize:vitalize_dev@localhost:5432/vitalize

# JWT — use long random secrets (min 64 chars). Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_minimum_64_char_random_secret_for_access_token_signing_xxx
JWT_REFRESH_SECRET=replace_with_different_minimum_64_char_random_secret_for_refresh_xxx
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Admin credentials (server-side only, never sent to the frontend).
# ADMIN_PASSWORD_HASH must be a bcrypt hash. Generate with:
#   node -e "import('bcryptjs').then(b=>b.default.hash('your_password',12).then(console.log))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$12$4YlVHFxs2hXc6oBl9c3uLeOoqU/xS9WcREJ5J9QOZcZTL7FZ9o5L6

# Demo non-admin user — same instructions for the hash
USER_USERNAME=reader
USER_PASSWORD_HASH=$2a$12$cWp9mFfW2oU5qxQpv/7XRu8oPpQ4QyfFGc/QcEqTeBSvvT3qQy3vO

# Operator-only secret. Required by POST /api/auth/admin/register so that
# the hidden /admin/register page can't be abused by anyone with the URL.
# Generate with: openssl rand -hex 24
ADMIN_INVITE_CODE=463
